# ── Student & Family Services Concierge — environment ──────────────────────────
# Demo (default): deterministic, no API key, fixtures.
EXTRACT_MODE=demo
CONNECTOR_MODE=fixture

# ── LLM provider ───────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# For private-connectivity inference via PrivateLink (no student-PII egress to external AI APIs) + Guardrails:
# LLM_PROVIDER=bedrock
# BEDROCK_REGION=us-east-1
# BEDROCK_GUARDRAIL_ID=...            # REQUIRED in production
# BEDROCK_GUARDRAIL_VERSION=DRAFT

# ── Identity / gateway ──────────────────────────────────────────────────────────
AUTH_ROLE_CLAIM=custom:edu_role
# AUTH_JWKS_URL=https://<idp>/.well-known/jwks.json
# AUTH_AUDIENCE=<app-client-id>
# GATEWAY_TOKEN_SECRET=<rotate-in-prod>
# GATEWAY_AUDIT_JSONL=/var/log/edu/concierge-audit.jsonl

# ── Live connectors (production) ────────────────────────────────────────────────
# CONNECTOR_MODE=live
# SIS_BASE_URL=https://sis.example.edu/api
# CRM_BASE_URL=https://crm.example.edu/api
# KB_BASE_URL=https://kb.example.edu/api

# ── Durable checkpointing (production) ───────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/edu

# ── Pilot data ────────────────────────────────────────────────────────────────
# Public questions use the live College Scorecard API (set a real key from
# https://api.data.gov/signup/ or leave DEMO_KEY for a rate-limited pilot).
SCORECARD_API_KEY=DEMO_KEY
# Authenticated status uses SYNTHETIC SIS data in the pilot (see runbooks/agent-deploy/01-PILOT.md).
# For production, point CONNECTOR_MODE=live + SIS_BASE_URL at the real SIS under a FERPA DPA.
